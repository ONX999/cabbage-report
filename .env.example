# 甘藍報表生成器環境配置範例
# 複製此檔案為 .env 並修改相應設定

# API 設定
CABBAGE_API_KEY=your_api_key_here
API_BASE_URL=https://data.coa.gov.tw/api/v1/AgriProductsTransType
API_TIMEOUT=30
API_RETRY_COUNT=3

# 資料設定
CABBAGE_CODES=FC01,FC02,FC03
MAX_QUERY_DAYS=90
CACHE_ENABLED=true

# 報表設定
OUTPUT_FORMATS=excel,pdf
INCLUDE_CHARTS=true
EXCEL_TEMPLATE_PATH=
PDF_TEMPLATE_PATH=

# 日誌設定
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/cabbage_report.log

# 環境設定
ENVIRONMENT=production
DEBUG=false